{
  "servers": {
    "supabaseLocal": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase",
        "--project-ref",
        "isrrqqdncniqtbjkyasn",
        "--features",
        "database,docs,debugging,development,functions,storage"
      ],
      "envFile": "${workspaceFolder}/.env.local"
    },
    "sequentialThinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--caps=vision"]
    }
  }
}